# ============================================
# Environment Variables Template
# ============================================

# Application Settings
ENVIRONMENT=development
DEBUG=True

# Database Settings
DB_HOST=postgres
DB_PORT=5432
DB_USER=vocab_user
DB_PASSWORD=vocab_pass
DB_NAME=vocab_db

# Database URL
DATABASE_URL=postgresql://vocab_user:vocab_pass@postgres:5432/vocab_db

# CORS Settings (Allow all origins during development)
CORS_ORIGINS=*

# ============================================
# Notes:
# - DB_HOST=postgres corresponds to the service name in docker-compose
# - Use simple passwords for local development; use strong passwords for production
# - CORS_ORIGINS=* is for development only; set to specific domains in production
# ============================================